{
  "name": "@sea-traces/client",
  "version": "5.5.0-beta.2",
  "description": "Sea Traces API client for universal JavaScript environments",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "author": "Sea Traces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seaart-ai/sea-traces-js.git",
    "directory": "packages/client"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@sea-traces/core": "workspace:^",
    "@sea-traces/tracing": "workspace:^",
    "mustache": "^4.2.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6"
  }
}
